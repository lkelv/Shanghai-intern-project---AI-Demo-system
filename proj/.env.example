# Copy this file to `.env` and fill in your key:  cp .env.example .env
# The real .env is git-ignored — never commit your key.
# Read server-side only (proj/server.js); it never reaches the browser.

# Required — your OpenRouter API key (https://openrouter.ai/keys)
OPEN_ROUTER_API_KEY = sk-or-v1-your-key-here

# Optional — model to use (default: openai/gpt-oss-20b)
# OPENROUTER_MODEL = openai/gpt-oss-20b

# Optional — port for the standalone Node backend, server.js (default: 8791).
# Only used by `npm run server` / `npm run dev:file`. The default `npm run dev`
# runs the Cloudflare Worker instead and ignores this.
# API_PORT = 8791
