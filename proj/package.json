{
  "name": "proj",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --env-file=.env server.js",
    "dev:file": "concurrently -n web,api -c cyan,green \"vite\" \"npm:server\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "cf:kv:create": "wrangler kv namespace create JOURNEY",
    "cf:secret": "wrangler secret put OPEN_ROUTER_API_KEY"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wrangler": "^4.106.0"
  }
}
